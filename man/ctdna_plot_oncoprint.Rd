                      alterations = c("Missense","Truncating"))

# Drop one noisy class without naming the other ten (blacklist form)
ctdna_plot_oncoprint(sim$infinity_report, Other = FALSE)

# Whitelist via individual flags (no need to remember the canonical names)
ctdna_plot_oncoprint(sim$infinity_report,
                      Focal_Amp = TRUE, Missense = TRUE)

# Discover the canonical names
ctdna_alteration_types()

# Wrap by indication; cumulative legend across panels
ctdna_plot_oncoprint(sim$infinity_report,
                      gene_sets       = "HRR14",
