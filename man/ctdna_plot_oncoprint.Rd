                      patient_data    = sim$clinical,
                      cancer_type     = "NSCLC",
                      cancer_type_col = "Cancertype",
                      top_annotations = "RECIST")

# Multiple gene-sets, separated horizontal bands, sorted within set
ctdna_plot_oncoprint(sim$infinity_report,
                      gene_sets = c("HRR14","TSG"),
                      sort_genes = "within_set")

# Restrict to a small set of alteration classes (canonical vector form)
